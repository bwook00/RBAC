# Discord bot credentials for the Access Control dashboard.
# Copy to `.env` (same dir or repo root) and fill in, then `bun run start`.

# Bot token from https://discord.com/developers/applications -> your app -> Bot.
# The bot must be invited to your server AND have the privileged
# "Server Members Intent" toggled ON (Bot settings) to list members.
DISCORD_BOT_TOKEN=

# Your Discord server (guild) ID. Enable Developer Mode in Discord, then
# right-click the server icon -> "Copy Server ID".
DISCORD_GUILD_ID=

# Optional: a specific channel ID (reserved for future channel scoping).
DISCORD_CHANNEL_ID=

# Optional overrides.
# PORT=4322
# DISCORD_TEAMS_PATH=.data/discord-rbac/teams.json
